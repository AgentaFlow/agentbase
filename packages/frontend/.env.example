# Agentbase Frontend Environment Variables
# Copy this file to .env.local and update values as needed.

# Backend Core API URL
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# AI Service URL
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000/api

# Marketplace Service URL (for purchases, licenses, developer portal)
NEXT_PUBLIC_MARKETPLACE_URL=http://localhost:3002/api/v1

# Stripe publishable key (obtain from Stripe dashboard)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
