{
  "name": "@agentbase/plugin-user-feedback-collector",
  "version": "1.0.0",
  "description": "Thumbs up/down rating after each AI response with optional comments. Aggregated quality scores per model and time period.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@agentbase/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "__tests__/tsconfig.json"
      }
    }
