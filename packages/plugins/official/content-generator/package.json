{
  "name": "@agentbase/plugin-content-generator",
  "version": "1.0.0",
  "description": "AI-powered content creation with 50+ prompt templates for blog posts, emails, social copy, and more.",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "test:cov": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@agentbase/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ],
    "globals": {
      "ts-jest": {
        "tsconfig": "./tsconfig.test.json"
      }
    },
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
