# Normalize line endings. Shell scripts and YAML must stay LF so they run on the
# Linux build agents regardless of the contributor's OS / core.autocrlf setting.
* text=auto eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.bicep text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
